node_modules/
dist/

# ── Secrets ───────────────────────────────────────────────────────────────────
# NEVER commit credentials. Use .env (local only).
.env

# ── Databases ─────────────────────────────────────────────────────────────────
# Binary vector/SQLite databases — not source code, can be large
*.db
*.sqlite
*.sqlite3

# ── Raw API snapshots ─────────────────────────────────────────────────────────
# Large, ephemeral, regenerated each pipeline run
store/raw/**/*.json
store/raw/**/*.json.gz

# ── Derived store data ────────────────────────────────────────────────────────
# Regenerated from raw — not source of truth
store/normalized/
store/validated/
store/dedup-index.json
store/source-cursors.json

# ── Runtime quota state ───────────────────────────────────────────────────────
quota/state.json

# ── Export outputs ────────────────────────────────────────────────────────────
# Regenerated by `npm run export`. .gitkeep files preserve directory structure.
exports/world-map/*.json
exports/oil-project/*.json
# Sample/contract files committed intentionally — not auto-generated
!exports/oil-project/oil-events.json
!exports/oil-project/energy-indicators.json
!exports/oil-project/manifest.json
exports/stock-project/*.json
exports/manifest.json

# ── Timeseries store — data files ────────────────────────────────────────────
# Annual price files grow daily and are regenerated by `npm run fetch-prices`.
# metadata.json and revision logs are tracked (schema + audit trail).
store/timeseries/commodities/*/[0-9][0-9][0-9][0-9].json
store/timeseries/structural/*/snapshots/

# ── Timeseries export outputs ─────────────────────────────────────────────────
# Regenerated by `npm run export` from the timeseries store.
# Gitignored because they change daily; serve via exports/ not git.
exports/oil-project/oil-prices.json
exports/oil-project/gas-prices.json
exports/oil-project/lng-prices.json

# ── Run logs ──────────────────────────────────────────────────────────────────
runs/

# ── Intelligence layer — runtime state ────────────────────────────────────────
# Regenerated by pipeline. Not source code.
intelligence/sources/source-health.json
intelligence/sources/fingerprint-index.json
intelligence/raw/
intelligence/outputs/
intelligence/memory/
intelligence/human/store.json
intelligence/human/analysis-store.json
intelligence/human/briefs.json

# ── Note: intelligence/metrics/*.json are intentionally NOT ignored ───────────
# Metrics history is tracked in git — it is the calibration record.
# See: intelligence/metrics/metrics-store.ts header comment.
