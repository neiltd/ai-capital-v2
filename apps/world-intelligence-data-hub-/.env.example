# NewsAPI — https://newsapi.org/  (free: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# EIA — https://www.eia.gov/opendata/  (free: 1,000 req/day)
EIA_KEY=your_eia_key_here

# ACLED — https://acleddata.com/  (OAuth2 credentials)
ACLED_USERNAME=your_email@example.com
ACLED_PASSWORD=your_acled_password_here
ACLED_TOKEN_URL=https://acleddata.com/oauth/token
ACLED_API_BASE_URL=https://acleddata.com/api/acled/read
ACLED_CLIENT_ID=acled
ACLED_SCOPE=authenticated

# GDELT — no key required (free, no auth)
# World Bank — no key required (free, no auth)

# Anthropic — https://console.anthropic.com/  (reporter-agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Admin panel — required to start admin/server.ts; requests must send
# `Authorization: Bearer <ADMIN_API_KEY>` or the server exits/rejects.
ADMIN_API_KEY=generate_a_long_random_secret_here

# Runtime
DEBUG=false
NODE_ENV=development
