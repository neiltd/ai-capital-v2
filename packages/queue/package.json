{
  "name": "@common/queue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "queue-submit": "./bin/submit.ts",
    "queue-worker": "./bin/worker.ts"
  },
  "scripts": {
    "typecheck":  "tsc --noEmit",
    "submit":     "tsx bin/submit.ts",
    "worker":     "tsx bin/worker.ts",
    "smoke":      "tsx bin/smoke.ts",
    "run-daily":  "tsx bin/run-daily.ts",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@common/pipeline-runs": "workspace:*",
    "bullmq":                "^5.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx":         "^4.16.0",
    "typescript":  "^5.5.0",
    "vitest":      "^2.0.0"
  }
}
